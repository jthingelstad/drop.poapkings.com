{
  "name": "@elixir-drop/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "backfill:all-time": "node scripts/backfill-all-time.mjs",
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node24 --format=cjs --sourcemap --outfile=dist/handler.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1090.0",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-sqs": "^3.1090.0",
    "@aws-sdk/lib-dynamodb": "^3.1090.0",
    "@aws-sdk/util-dynamodb": "^3.996.7",
    "@elixir-drop/contracts": "*",
    "@elixir-drop/game-data": "^0.1.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
