{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/main.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "scripts/*.mjs",
    "tests/**/*.{ts,tsx}"
  ],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.mjs", "tests/**/*.{ts,tsx}", "*.config.ts"],
  "ignore": [
    "src/modes/blitz/**",
    "src/modes/cost-sweep/**",
    "src/modes/endless-ladder/**",
    "src/modes/identify/**",
    "src/modes/ladder/**",
    "src/components/PenaltyFlash.tsx"
  ],
  "vite": false
}
