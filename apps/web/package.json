{
  "name": "@elixir-drop/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e -- --project=chromium --project=iphone-14",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "og": "node scripts/render-og.mjs",
    "verify": "npm run format:check && npm run lint && npm run lint:css && npm run typecheck && npm run knip && npm run test:unit && npm run test:e2e -- --project=chromium --project=iphone-14 && npm run build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{ts,js,json}\" \"*.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{ts,js,json}\" \"*.config.ts\"",
    "lint": "oxlint . --deny-warnings",
    "lint:css": "stylelint \"src/styles.css\"",
    "knip": "knip --no-config-hints --include files,dependencies,unlisted"
  },
  "dependencies": {
    "@elixir-drop/contracts": "*",
    "@elixir-drop/game-data": "*",
    "@preact/signals": "^2.9.4",
    "preact": "^10.29.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.9.5",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "oxlint": "^1.74.0",
    "preact-render-to-string": "^6.7.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
