# CR_API_TOKEN (or CR_API_KEY) — used ONLY by scripts/refresh-cards.mjs on the managed host.
# Never commit this value. Never read it in client or CI code.
CR_API_TOKEN=your_clash_royale_api_token_here

# Set to true to download card images to public/cards/{id}.png instead of hotlinking the CR CDN.
# Flipping this later requires no game-code changes.
MIRROR_IMAGES=false
