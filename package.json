{
  "name": "elixir-drop-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infra"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@elixir-drop/web",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspace=@elixir-drop/web",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspace=@elixir-drop/web",
    "test:e2e": "npm run test:e2e --workspace=@elixir-drop/web --",
    "verify": "npm run format:check && npm run lint && npm run verify:workspaces",
    "verify:workspaces": "npm run verify --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"{apps,services,packages/contracts,infra}/**/*.{ts,tsx,mjs,json,yml,yaml}\" \".github/**/*.{yml,yaml}\" \"*.{json,jsonc}\"",
    "format:check": "prettier --check \"{apps,services,packages/contracts,infra}/**/*.{ts,tsx,mjs,json,yml,yaml}\" \".github/**/*.{yml,yaml}\" \"*.{json,jsonc}\"",
    "lint": "oxlint --type-aware --type-check --deny-warnings --report-unused-disable-directives .",
    "lint:css": "npm run lint:css --workspaces --if-present",
    "knip": "npm run knip --workspaces --if-present",
    "og": "npm run og --workspace=@elixir-drop/web",
    "bootstrap:aws": "npm run bootstrap --workspace=@elixir-drop/infra",
    "deploy:api": "npm run deploy --workspace=@elixir-drop/infra",
    "smoke:api": "npm run smoke --workspace=@elixir-drop/infra",
    "check:beta": "npm audit --audit-level=high && npm run verify && npm run smoke:api",
    "verify:deploy": "npm run format:check && npm run lint && npm run verify:deploy --workspace=@elixir-drop/web && npm run verify --workspace=@elixir-drop/api && npm run verify --workspace=@elixir-drop/cr-api-bridge && npm run verify --workspace=@elixir-drop/infra"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "prettier": "^3.9.5"
  }
}
