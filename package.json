{
  "name": "elixir-drop-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infra"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@elixir-drop/web",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspace=@elixir-drop/web",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspace=@elixir-drop/web",
    "test:e2e": "npm run test:e2e --workspace=@elixir-drop/web --",
    "verify": "npm run verify --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:css": "npm run lint:css --workspaces --if-present",
    "knip": "npm run knip --workspaces --if-present",
    "og": "npm run og --workspace=@elixir-drop/web",
    "bootstrap:aws": "npm run bootstrap --workspace=@elixir-drop/infra",
    "deploy:api": "npm run deploy --workspace=@elixir-drop/infra",
    "smoke:api": "npm run smoke --workspace=@elixir-drop/infra"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
